{
  "name": "schedule-management",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "build:electron:sync": "powershell -ExecutionPolicy Bypass -File .\\scripts\\electron-shell.ps1 -Step sync",
    "build:electron:portable": "powershell -ExecutionPolicy Bypass -File .\\scripts\\electron-shell.ps1 -Target portable",
    "build:electron:setup": "powershell -ExecutionPolicy Bypass -File .\\scripts\\electron-shell.ps1 -Target setup",
    "build:electron:green": "powershell -ExecutionPolicy Bypass -File .\\scripts\\electron-shell.ps1 -Target green",
    "build:electron:all": "powershell -ExecutionPolicy Bypass -File .\\scripts\\electron-shell.ps1 -Target all",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "dayjs": "^1.11.13",
    "element-plus": "^2.8.8",
    "exceljs": "^4.4.0",
    "idb": "^8.0.0",
    "lodash-es": "^4.17.21",
    "sortablejs": "^1.15.3",
    "vue": "^3.5.13",
    "vue-router": "^4.4.5",
    "vuedraggable": "^4.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/sortablejs": "^1.15.8",
    "@vitejs/plugin-vue": "^5.2.1",
    "sass": "^1.80.0",
    "sass-embedded": "^1.93.3",
    "typescript": "~5.6.3",
    "vite": "^6.0.1",
    "vue-tsc": "^2.1.10"
  }
}
